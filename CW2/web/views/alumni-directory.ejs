<%- include('partials/document-start', {
  pageTitle,
  bodyClass,
  analyticsEndpoint: null,
  currentUserEmail: null,
  csrfCookieName: null
}) %>
<%
  const filterOptions = directoryData?.filterOptions || {
    programmes: [],
    industrySectors: []
  }
%>
    <div class="container-fluid py-4 px-3 px-lg-4">
      <%- include('partials/dashboard-header', {
        title: 'Alumni By Programme',
        description: 'Filter alumni by programme, graduation window, and industry sector.',
        currentUserEmail: currentUser.email,
        menuId: 'directory-header-actions',
        actions: [
          { href: '/dashboard/alumni-analytics', label: 'Analytics' },
          { href: '/bidding', label: 'Bidding' },
          { href: '/login', label: 'Switch account' }
        ]
      }) %>

      <% if (directoryError) { %>
        <section id="dashboard-error" class="card shadow-sm border-0 mb-4 dashboard-error">
          <div class="card-body">
            <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3">
              <div>
                <p class="text-uppercase small fw-semibold text-danger mb-2">Directory Status</p>
                <h2 id="dashboard-error-title" class="h4 mb-2">Alumni directory unavailable</h2>
                <p id="dashboard-error-message" class="text-secondary mb-0"><%= directoryError %></p>
              </div>
              <div class="d-flex gap-2">
                <a href="<%= retryPath %>" class="btn btn-danger">Retry</a>
              </div>
            </div>
          </div>
        </section>
      <% } %>

      <section id="directory-controls" class="card shadow-sm border-0 mb-4">
        <div class="card-body">
          <form method="get" action="/dashboard/alumni-directory" class="d-flex flex-column gap-3">
            <div class="row g-3 align-items-end">
              <div class="col-12 col-md-6 col-xl-3">
                <label class="form-label" for="filter-programme">Programme</label>
                <select class="form-select" id="filter-programme" name="programme">
                  <option value="">All programmes</option>
                  <% filterOptions.programmes.forEach((programme) => { %>
                    <option value="<%= programme %>" <%= directoryFilters.programme === programme ? 'selected' : '' %>><%= programme %></option>
                  <% }) %>
                </select>
              </div>
              <div class="col-12 col-md-6 col-xl-3">
                <label class="form-label" for="filter-graduation-from">Graduation from</label>
                <input class="form-control" type="date" id="filter-graduation-from" name="graduationFrom" value="<%= directoryFilters.graduationFrom || '' %>">
              </div>
              <div class="col-12 col-md-6 col-xl-3">
                <label class="form-label" for="filter-graduation-to">Graduation to</label>
                <input class="form-control" type="date" id="filter-graduation-to" name="graduationTo" value="<%= directoryFilters.graduationTo || '' %>">
              </div>
              <div class="col-12 col-md-6 col-xl-3">
                <label class="form-label" for="filter-industry-sector">Industry sector</label>
                <select class="form-select" id="filter-industry-sector" name="industrySector">
                  <option value="">All industry sectors</option>
                  <% filterOptions.industrySectors.forEach((sector) => { %>
                    <option value="<%= sector %>" <%= directoryFilters.industrySector === sector ? 'selected' : '' %>><%= sector %></option>
                  <% }) %>
                </select>
              </div>
            </div>

            <div class="d-flex flex-wrap gap-2">
              <button type="submit" class="btn btn-dark">Apply filters</button>
              <a href="/dashboard/alumni-directory" class="btn btn-outline-secondary">Clear filters</a>
              <a href="<%= retryPath %>" class="btn btn-outline-secondary">Refresh</a>
            </div>
          </form>
        </div>
      </section>

      <% if (directoryData) { %>
        <section id="directory-content">
          <section class="row g-3 mb-4">
            <div class="col-12 col-lg-4">
              <article class="card shadow-sm border-0 summary-card">
                <div class="card-body">
                  <div class="text-secondary small mb-2">Matching alumni</div>
                  <div class="fs-3 fw-bold text-dark" id="directory-total-count"><%= directoryData.totalCount %></div>
                </div>
              </article>
            </div>
          </section>

          <section class="card shadow-sm border-0">
            <div class="card-body">
              <div class="table-responsive">
                <table class="table align-middle mb-0">
                  <thead>
                    <tr>
                      <th>Name</th>
                      <th>Email</th>
                      <th>Programme</th>
                      <th>Graduation date</th>
                      <th>Latest job</th>
                      <th>Company</th>
                      <th>Industry sector</th>
                    </tr>
                  </thead>
                  <tbody id="directory-results-body">
                    <% if (!directoryData.alumni.length) { %>
                      <tr>
                        <td colspan="7" class="text-secondary text-center py-4">No alumni matched the current filters.</td>
                      </tr>
                    <% } %>

                    <% directoryData.alumni.forEach((person) => { %>
                      <tr>
                        <td><a href="/alumni/<%= encodeURIComponent(person.userId) %>"><%= person.name %></a></td>
                        <td><%= person.email %></td>
                        <td><%= person.programme %></td>
                        <td><%= person.graduationDate %></td>
                        <td><%= person.latestEmployment?.jobTitle || '—' %></td>
                        <td><%= person.latestEmployment?.company || '—' %></td>
                        <td><%= person.latestEmployment?.industrySector || '—' %></td>
                      </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>
            </div>
          </section>
        </section>
      <% } %>
    </div>

<%- include('partials/document-end', {
  scriptPaths: ['/assets/header-menu.js']
}) %>
