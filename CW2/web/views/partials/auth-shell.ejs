<main class="container min-vh-100 d-flex align-items-center py-5">
  <section class="row justify-content-center w-100">
    <div class="<%= widthClass %>">
      <div class="card shadow-sm border-0">
        <div class="card-body p-4 p-lg-5">
          <p class="text-uppercase small fw-semibold text-primary mb-2"><%= eyebrow %></p>
          <h1 class="h3 mb-3"><%= title %></h1>
          <% if (description) { %>
            <p class="text-secondary mb-4"><%= description %></p>
          <% } %>
          <%- include(contentPartial) %>
        </div>
      </div>
    </div>
  </section>
</main>
