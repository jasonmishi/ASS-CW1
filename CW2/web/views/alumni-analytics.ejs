<%- include('partials/document-start', {
  pageTitle,
  bodyClass,
  analyticsEndpoint: null,
  currentUserEmail: null,
  csrfCookieName: null
}) %>
<%
  const filterOptions = analyticsData?.filterOptions || {
    degreeTitles: [],
    credentialDomains: [],
    careerCategories: [],
    dateBounds: { min: '', max: '' }
  }
  const charts = analyticsData?.charts || {}
  const chartCards = [
    { id: 'degreeTitles', columnClass: 'col-12 col-lg-6', wrapClass: 'chart-canvas-wrap' },
    { id: 'qualificationMix', columnClass: 'col-12 col-lg-6', wrapClass: 'chart-canvas-wrap chart-canvas-wrap-circular' },
    { id: 'learningTimeline', columnClass: 'col-12', wrapClass: 'chart-canvas-wrap chart-canvas-wrap-wide' },
    { id: 'topCertifications', columnClass: 'col-12 col-lg-6', wrapClass: 'chart-canvas-wrap' },
    { id: 'topCourses', columnClass: 'col-12 col-lg-6', wrapClass: 'chart-canvas-wrap' },
    { id: 'certificationCoverage', columnClass: 'col-12 col-lg-6', wrapClass: 'chart-canvas-wrap chart-canvas-wrap-circular' },
    { id: 'careerPathways', columnClass: 'col-12 col-lg-6', wrapClass: 'chart-canvas-wrap' },
    { id: 'developmentRadar', columnClass: 'col-12 col-lg-6', wrapClass: 'chart-canvas-wrap' }
  ]
%>
    <div class="container-fluid py-4 px-3 px-lg-4">
      <%- include('partials/dashboard-header', {
        title: 'Alumni Analytics',
        description: 'Qualification growth and career pathways across the alumni database.',
        currentUserEmail: currentUser.email,
        menuId: 'analytics-header-actions',
        actions: [
          { href: '/dashboard/alumni-directory', label: 'Directory' },
          { href: '/bidding', label: 'Bidding' },
          { href: '/login', label: 'Switch account' }
        ]
      }) %>

      <% if (analyticsError) { %>
        <section id="dashboard-error" class="card shadow-sm border-0 mb-4 dashboard-error">
          <div class="card-body">
            <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3">
              <div>
                <p class="text-uppercase small fw-semibold text-danger mb-2">Dashboard Status</p>
                <h2 id="dashboard-error-title" class="h4 mb-2">Analytics dashboard unavailable</h2>
                <p id="dashboard-error-message" class="text-secondary mb-0"><%= analyticsError %></p>
              </div>
              <div class="d-flex gap-2">
                <a href="<%= retryPath %>" class="btn btn-danger">Retry</a>
              </div>
            </div>
          </div>
        </section>
      <% } %>

      <section id="dashboard-controls" class="card shadow-sm border-0 mb-4">
        <div class="card-body">
          <form method="get" action="/dashboard/alumni-analytics" class="d-flex flex-column gap-3">
            <div class="row g-3">
              <div class="col-12 col-md-6 col-xl-2">
                <label class="form-label" for="filter-from">From</label>
                <input
                  class="form-control"
                  type="date"
                  id="filter-from"
                  name="from"
                  value="<%= analyticsFilters.from || '' %>"
                  min="<%= filterOptions.dateBounds.min || '' %>"
                  max="<%= filterOptions.dateBounds.max || '' %>"
                >
              </div>
              <div class="col-12 col-md-6 col-xl-2">
                <label class="form-label" for="filter-to">To</label>
                <input
                  class="form-control"
                  type="date"
                  id="filter-to"
                  name="to"
                  value="<%= analyticsFilters.to || '' %>"
                  min="<%= filterOptions.dateBounds.min || '' %>"
                  max="<%= filterOptions.dateBounds.max || '' %>"
                >
              </div>
              <div class="col-12 col-md-6 col-xl-2">
                <label class="form-label" for="filter-degree">Degree title</label>
                <select class="form-select" id="filter-degree" name="degreeTitle">
                  <option value="">All degree titles</option>
                  <% filterOptions.degreeTitles.forEach((degreeTitle) => { %>
                    <option value="<%= degreeTitle %>" <%= analyticsFilters.degreeTitle === degreeTitle ? 'selected' : '' %>><%= degreeTitle %></option>
                  <% }) %>
                </select>
              </div>
              <div class="col-12 col-md-6 col-xl-2">
                <label class="form-label" for="filter-domain">Credential domain</label>
                <select class="form-select" id="filter-domain" name="credentialDomain">
                  <option value="">All domains</option>
                  <% filterOptions.credentialDomains.forEach((domain) => { %>
                    <option value="<%= domain.key %>" <%= analyticsFilters.credentialDomain === domain.key ? 'selected' : '' %>><%= domain.label %></option>
                  <% }) %>
                </select>
              </div>
              <div class="col-12 col-md-6 col-xl-2">
                <label class="form-label" for="filter-career">Career pathway</label>
                <select class="form-select" id="filter-career" name="careerCategory">
                  <option value="">All pathways</option>
                  <% filterOptions.careerCategories.forEach((career) => { %>
                    <option value="<%= career.key %>" <%= analyticsFilters.careerCategory === career.key ? 'selected' : '' %>><%= career.label %></option>
                  <% }) %>
                </select>
              </div>
              <div class="col-12 col-md-6 col-xl-2">
                <label class="form-label" for="filter-search">Search</label>
                <input class="form-control" type="search" id="filter-search" name="search" value="<%= analyticsFilters.search || '' %>" placeholder="AWS, Scrum, Data Analyst...">
              </div>
            </div>

            <div class="d-flex flex-wrap gap-2">
              <button type="submit" class="btn btn-dark">Apply filters</button>
              <a href="/dashboard/alumni-analytics" class="btn btn-outline-secondary">Clear filters</a>
              <a href="<%= retryPath %>" class="btn btn-outline-secondary">Refresh</a>
              <button type="button" id="export-csv" class="btn btn-outline-secondary" <%= analyticsData ? '' : 'disabled' %>>Export CSV</button>
              <button type="button" id="generate-report" class="btn btn-primary" <%= analyticsData ? '' : 'disabled' %>>Generate PDF report</button>
            </div>
          </form>

          <% if (analyticsData) { %>
            <div class="d-flex flex-wrap gap-2 mt-3" id="report-selectors">
              <% chartOrder.forEach((chartId) => { %>
                <% if (charts[chartId]) { %>
                  <label class="report-choice form-check form-check-inline border rounded-pill px-3 py-2 bg-white">
                    <input class="form-check-input me-2" type="checkbox" value="<%= chartId %>" checked>
                    <span class="form-check-label"><%= charts[chartId].title %></span>
                  </label>
                <% } %>
              <% }) %>
            </div>
          <% } %>
        </div>
      </section>

      <% if (analyticsData) { %>
        <section class="row g-3 mb-4" id="summary-grid">
          <% analyticsData.summary.forEach((card) => { %>
            <div class="col-12 col-sm-6 col-xl-2">
              <article class="card shadow-sm border-0 summary-card">
                <div class="card-body">
                  <div class="text-secondary small mb-2"><%= card.label %></div>
                  <div class="fs-3 fw-bold text-<%= card.tone === 'neutral' ? 'dark' : card.tone === 'highlight' ? 'primary' : card.tone === 'accent' ? 'warning' : card.tone %>"><%= card.value %></div>
                </div>
              </article>
            </div>
          <% }) %>
        </section>

        <section class="row g-3 mb-4" id="insights-panel">
          <% if (!analyticsData.insights.length) { %>
            <div class="col-12">
              <article class="card shadow-sm border-0 insight-card">
                <div class="card-body">
                  <strong class="d-block mb-1">No major gaps detected.</strong>
                  <span class="text-secondary">The current filtered cohort does not trigger any configured critical or emerging signals.</span>
                </div>
              </article>
            </div>
          <% } %>

          <% analyticsData.insights.forEach((insight) => { %>
            <div class="col-12 col-md-6">
              <article class="card shadow-sm border-0 insight-card severity-<%= insight.severity %>">
                <div class="card-body">
                  <strong class="d-block mb-1"><%= insight.title %></strong>
                  <span class="text-secondary"><%= insight.description %></span>
                </div>
              </article>
            </div>
          <% }) %>
        </section>

        <main class="row g-4" id="dashboard-main">
          <section class="col-12 col-xl-9">
            <div class="row g-4">
              <% chartCards.forEach((chartCard) => { %>
                <% const chart = charts[chartCard.id] %>
                <% if (chart) { %>
                  <div class="<%= chartCard.columnClass %>">
                    <article class="card shadow-sm border-0 h-100" data-chart-id="<%= chartCard.id %>">
                      <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                          <div>
                            <h2 class="h5 mb-1"><%= chart.title %></h2>
                            <p class="text-secondary small mb-0"><%= chart.subtitle %></p>
                          </div>
                          <button type="button" class="btn btn-outline-secondary btn-sm chart-download" data-chart-download="<%= chartCard.id %>">Download image</button>
                        </div>
                        <div class="<%= chartCard.wrapClass %>">
                          <canvas id="chart-<%= chartCard.id %>"></canvas>
                        </div>
                      </div>
                    </article>
                  </div>
                <% } %>
              <% }) %>
            </div>
          </section>

          <aside class="col-12 col-xl-3">
            <div class="card shadow-sm border-0 detail-panel p-2" id="detail-panel">
              <div class="card-body">
                <% if (detailPanel) { %>
                  <h2 class="h5"><%= detailPanel.title %></h2>
                  <p class="detail-kicker"><%= detailPanel.item.label %></p>
                  <p class="detail-value"><%= detailPanel.item.value %></p>
                  <p class="mb-0"><%= detailPanel.subtitle %></p>
                <% } else { %>
                  <h2 class="h5">Detail Panel</h2>
                  <p class="text-secondary mb-0">Apply filters or click a selectable chart element to reload the page with a focused view.</p>
                <% } %>
              </div>
            </div>
          </aside>
        </main>

        <script id="analytics-dashboard-state" type="application/json"><%- dashboardClientStateJson %></script>
      <% } %>
    </div>

<%- include('partials/document-end', {
  scriptPaths: analyticsData
    ? [
        '/vendor/chart.js/chart.umd.js',
        '/vendor/jspdf/jspdf.umd.min.js',
        '/assets/header-menu.js',
        '/assets/dashboard.js'
      ]
    : ['/assets/header-menu.js']
}) %>
