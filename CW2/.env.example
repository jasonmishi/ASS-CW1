# Core runtime
NODE_ENV=development
DATABASE_URL=postgres://postgres:postgres@localhost:5432/alum
PORT=3000

# Auth and session
JWT_SECRET=change-me-jwt-secret
JWT_EXPIRES_IN=1h
ACCESS_TOKEN_COOKIE_NAME=access_token
ACCESS_TOKEN_COOKIE_SAMESITE=lax

# CSRF and CORS
CSRF_SECRET=change-me-csrf-secret
CSRF_COOKIE_NAME=csrf_token
CSRF_COOKIE_SAMESITE=lax
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
RATE_LIMIT_TRUST_PROXY=false

# Password hashing and token TTLs
BCRYPT_SALT_ROUNDS=12
EMAIL_VERIFICATION_TTL_HOURS=24
PASSWORD_RESET_TTL_HOURS=1

# Email delivery
# Use `log` in local/test environments to avoid SMTP dependency.
EMAIL_TRANSPORT=log
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
EMAIL_FROM=noreply@eastminster.local
APP_BASE_URL=http://localhost:3000
PUBLIC_API_BASE_URL=
ANALYTICS_DASHBOARD_API_TOKEN=
ANALYTICS_ALUMNI_DIRECTORY_API_TOKEN=
INTERNAL_API_BASE_URL=http://127.0.0.1:3000

# Profile image storage
# Use `local` for non-production single-instance development only.
# Use `minio` for Docker-based or horizontally scaled deployments.
STORAGE_PROVIDER=local
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=profile-images
MINIO_PUBLIC_URL=http://localhost:9000

# Bootstrap first admin (used only when no admin exists yet)
BOOTSTRAP_ADMIN_EMAIL=admin@eastminster.ac.uk
BOOTSTRAP_ADMIN_USERNAME=admin@eastminster.ac.uk
BOOTSTRAP_ADMIN_PASSWORD=ChangeMe!123!

# Scheduler worker
SCHEDULER_SYSTEM_EMAIL=system.scheduler@eastminster.local
SCHEDULER_TICK_MS=30000
SPONSORSHIP_EXPIRY_INTERVAL_MS=300000
RATE_LIMIT_CLEANUP_INTERVAL_MS=300000

# Integration test compose helper (docker-compose.test.yml)
TEST_DB_PORT=55433
